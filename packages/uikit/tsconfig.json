{
  "extends": "@foxone/dev/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@foxone/uikit": ["./src/index.ts"],
      "@foxone/uikit/*": ["./src/*"]
    },
    "types": ["vuetify", "node"],
    "skipLibCheck": true
